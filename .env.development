# Optional: direct link for section-two video (CDN, storage, etc.). If unset, play uses /SectionTwoVideo.mp4 from public/.
# REACT_APP_SECTION_TWO_VIDEO_URL=

# React 19 + CRA Fast Refresh can emit partial HMR chunks where the refresh
# signature helper (_s / $RefreshSig$) is missing — causing "TypeError: _s is not a function".
# Full reload on save is stable; set to true only if you upgrade react-refresh / tooling.
FAST_REFRESH=false
